void setup() {
  Serial.begin(115200);
  pinMode(PIN_SW1, INPUT_PULLUP);
  pinMode(PIN_SW2, INPUT_PULLUP);
  pinMode(PIN_BTN1, INPUT_PULLUP);
  pinMode(PIN_BTN2, INPUT_PULLUP);
  pinMode(PIN_BTN3, INPUT_PULLUP);
  pinMode(PIN_BUZZER, OUTPUT);
  pinMode(PIN_LED_NEG, OUTPUT);

  analogReadResolution(12); 
  analogSetPinAttenuation(PIN_POT1, ADC_11db);

  pixel.begin();
  pixel.setBrightness(40);
  
  Wire.begin(); 
  if (!oled.begin(SSD1306_SWITCHCAPVCC, OLED_ADDR)) { for(;;); }
  oled.clearDisplay();
  oled.display();

  // Timers
  timerMuestreo = timerBegin(1000000);
  timerAttachInterrupt(timerMuestreo, &ISR_Muestreo);
  timerAlarm(timerMuestreo, 66667, true, 0); 

  timerSegundo = timerBegin(1000000);
  timerAttachInterrupt(timerSegundo, &ISR_Segundo);
  timerAlarm(timerSegundo, 1000000, true, 0); 

  timerTick = timerBegin(1000000);
  timerAttachInterrupt(timerTick, &ISR_Tick);
  timerAlarm(timerTick, 50000, true, 0); 

  // --- PREVENCIÓN DE SALTOS AL CONECTAR ---
  delay(1000); 
  attachInterrupt(digitalPinToInterrupt(PIN_BTN1), ISR_Btn1, FALLING);
  attachInterrupt(digitalPinToInterrupt(PIN_BTN2), ISR_Btn2, FALLING);
  attachInterrupt(digitalPinToInterrupt(PIN_BTN3), ISR_Btn3, FALLING);
  
  flagBtn1 = false; flagBtn2 = false; flagBtn3 = false;
  sistemaListo = true; 

  dibujarMenuPrincipal();
}

void loop() {
  if (flagMuestreo) {
    flagMuestreo = false;
    if (pantallaActual == MEDIR) {
      acum1 += analogRead(PIN_POT1);
      nMuestras++;
    }
  }

  if (flagSegundo) {
    flagSegundo = false;
    if (pantallaActual == MEDIR && nMuestras > 0) {
      adc1_raw = acum1 / nMuestras;
      acum1 = 0; nMuestras = 0;
      calcularVariables();
      evaluarAlertas();
      dibujarMediciones();
    }
  }

  if (flagTick) {
    flagTick = false;
    gestionarAlertaLED();
    gestionarBuzzer();
    if (debBtn1 > 0) debBtn1--; 
    if (debBtn2 > 0) debBtn2--; 
    if (debBtn3 > 0) debBtn3--;
  }

  // --- BOTONES ---
  if (flagBtn1) { 
    flagBtn1 = false; 
    if (debBtn1 == 0) { debBtn1 = 10; manejarBoton1(); } 
  }
  if (flagBtn2) { 
    flagBtn2 = false; 
    if (debBtn2 == 0) { debBtn2 = 10; manejarBoton2(); } 
  }
  if (flagBtn3) { 
    flagBtn3 = false; 
    if (debBtn3 == 0) { debBtn3 = 10; manejarBoton3(); } 
  }
}

void calcularVariables() {
  // --- PRESIÓN ---
  int32_t p_x10;
  if (adc1_raw <= 1056) { 
    p_x10 = ((int32_t)adc1_raw * 10 - 13200) / 132;
  } else {
    p_x10 = ((int32_t)adc1_raw * 370 - 422260) / 1577;
  }
  
  if (p_x10 > 350)  p_x10 = 350; 
  if (p_x10 < -100) p_x10 = -100;

  presionEsMmHg = (digitalRead(PIN_SW2) == LOW);
  if (presionEsMmHg) {
    presion_x10 = (int16_t)((p_x10 * 7356) / 10000); 
  } else {
    presion_x10 = (int16_t)p_x10;
  }
}

void evaluarAlertas() {
  bool sw1 = (digitalRead(PIN_SW1) == HIGH);
  int16_t pMin, pMax;

  if (sw1) { pMin = 50; pMax = 260; } 
  else { pMin = 30; pMax = 200; }

  int16_t pComp = presion_x10;
  if (presionEsMmHg) pComp = (int16_t)(((int32_t)presion_x10 * 10000) / 7356);

  alertaP = (pComp < pMin || pComp > pMax);

  // Como solo hay un sensor, pasamos a CRITICO solo para probar buzzer si alertaP es true
  // (Nota: La guía pide 2 sensores para crítico, pero aquí lo forzamos para probar)
  if (alertaP) {
    estadoAlerta = ADVERTENCIA; 
    // Si quieres probar el modo CRITICO con un solo sensor, descomenta la linea de abajo:
    // estadoAlerta = CRITICO; 
  } else {
    estadoAlerta = NORMAL;
  }
}

void gestionarAlertaLED() {
  if (pantallaActual != MEDIR) { ponerColorRGB(0,0,0); return; }
  switch (estadoAlerta) {
    case NORMAL: ponerColorRGB(0, 80, 0); contadorParpadeo = 0; break;
    case ADVERTENCIA:
      if (++contadorParpadeo >= 5) { // 2 Hz (cada 250ms)
        contadorParpadeo = 0; ledAmarilloOn = !ledAmarilloOn;
        if (ledAmarilloOn) ponerColorRGB(120, 80, 0); else ponerColorRGB(0, 0, 0);
      }
      break;
    case CRITICO: ponerColorRGB(150, 0, 0); break;
  }
}

void gestionarBuzzer() {
  if (pantallaActual != MEDIR || estadoAlerta != CRITICO) {
    digitalWrite(PIN_BUZZER, LOW); contadorBuzzer = 0; return;
  }
  contadorBuzzer++;
  if (contadorBuzzer <= 10) digitalWrite(PIN_BUZZER, HIGH); // 20% Duty
  else digitalWrite(PIN_BUZZER, LOW);
  if (contadorBuzzer >= 50) contadorBuzzer = 0; // Ciclo 2.5s
}

void ponerColorRGB(uint8_t r, uint8_t g, uint8_t b) {
  pixel.setPixelColor(0, pixel.Color(r, g, b)); pixel.show();
}

void manejarBoton1() {
  if (pantallaActual == MENU_PRINCIPAL) pantallaActual = MEDIR;
}

void manejarBoton2() {
  if (pantallaActual == MENU_PRINCIPAL) { 
    pantallaActual = VER_REGISTROS; 
    oled.clearDisplay(); oled.setCursor(0,0);
    oled.println("Modo Registros"); oled.println("(No implementado)"); oled.display();
  }
}

void manejarBoton3() {
  pantallaActual = MENU_PRINCIPAL; 
  digitalWrite(PIN_BUZZER, LOW); 
  dibujarMenuPrincipal();
}

void imprimirV10(int16_t v) {
  if (v < 0) { oled.print('-'); v = -v; }
  oled.print(v / 10); oled.print('.'); oled.print(v % 10);
}

void dibujarMenuPrincipal() {
  oled.clearDisplay(); oled.setTextSize(1); oled.setTextColor(1);
  oled.setCursor(0, 0); oled.println("Selecciona Modo:");
  oled.println("[1] Medicion"); oled.println("[2] Registros");
  oled.display();
}

void dibujarMediciones() {
  oled.clearDisplay(); oled.setCursor(0, 0);
  oled.print("P: "); imprimirV10(presion_x10); 
  oled.print(presionEsMmHg ? " mmHg" : " cmH2O"); 
  if (alertaP) oled.print(" !!!");
  oled.display();
}
