#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>
#include <Adafruit_NeoPixel.h>

// --- PINES ---
#define PIN_POT1      4    // Presión (ÚNICO ACTIVO)
// #define PIN_POT2      5    // Oxígeno (COMENTADO)
// #define PIN_POT3      6    // Flujo (COMENTADO)
#define PIN_SW1       17   // Rango de seguridad
#define PIN_SW2       15   // Unidades (cmH2O / mmHg)
// #define PIN_SW3       16   // SW Registros (COMENTADO)
#define PIN_BTN1      18   // Ir a Medición
#define PIN_BTN2      13   // Ir a Registros (Inactivo por ahora)
#define PIN_BTN3      46   // Volver al Menú
#define PIN_BUZZER    10
#define PIN_LED_NEG   14   // LED Polaridad (No se usa en medición directa)
#define PIN_NEOPIXEL  48   

#define ANCHO_OLED    128
#define ALTO_OLED     64
#define OLED_RESET    -1 
#define OLED_ADDR     0x3C

Adafruit_SSD1306 oled(ANCHO_OLED, ALTO_OLED, &Wire, OLED_RESET);
Adafruit_NeoPixel pixel(1, PIN_NEOPIXEL, NEO_GRB + NEO_KHZ800);

// --- ESTADOS ---
enum Pantalla { MENU_PRINCIPAL, MEDIR, VER_REGISTROS };
volatile Pantalla pantallaActual = MENU_PRINCIPAL;
enum Alerta { NORMAL, ADVERTENCIA, CRITICO };
Alerta estadoAlerta = NORMAL;

// --- TIMERS Y BANDERAS ---
hw_timer_t *timerMuestreo = NULL;
hw_timer_t *timerSegundo  = NULL;
hw_timer_t *timerTick     = NULL;

volatile bool flagMuestreo = false, flagSegundo = false, flagTick = false;
volatile bool flagBtn1 = false, flagBtn2 = false, flagBtn3 = false;
bool sistemaListo = false; // Bloqueo de ruido al arrancar

// --- ISRs ---
void IRAM_ATTR ISR_Muestreo(){ flagMuestreo = true; }
void IRAM_ATTR ISR_Segundo()  { flagSegundo  = true; }
void IRAM_ATTR ISR_Tick()     { flagTick     = true; }
void IRAM_ATTR ISR_Btn1() { if(sistemaListo) flagBtn1 = true; }
void IRAM_ATTR ISR_Btn2() { if(sistemaListo) flagBtn2 = true; }
void IRAM_ATTR ISR_Btn3() { if(sistemaListo) flagBtn3 = true; }

// --- VARIABLES DE DATOS ---
uint32_t acum1 = 0; // Solo acumulador de presión
uint8_t  nMuestras = 0;
int16_t  adc1_raw = 0;
int16_t  presion_x10 = 0;   
bool     presionEsMmHg = false;
bool     alertaP = false;

// --- GESTIÓN DE TIEMPOS ---
uint8_t contadorParpadeo = 0, debBtn1 = 0, debBtn2 = 0, debBtn3 = 0;
bool ledAmarilloOn = false;
uint16_t contadorBuzzer = 0; 

// --- ESTRUCTURA REGISTROS (COMENTADO) ---
